generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  displayName String?  @default("")
  email       String   @unique
  password    String
  avatar      String?  @default("/default-avatar.png")
  bio         String?  @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts             Post[]
  comments          Comment[]
  guestbookMessages  GuestbookMessage[]
}

model Post {
  id          String    @id @default(cuid())
  publicId    Int?      @unique
  title       String
  slug        String    @unique
  content     String
  excerpt     String    @default("")
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  pinned      Boolean   @default(false)  // 置顶
  views       Int       @default(0)
  likes       Int       @default(0)
  reposts     Int       @default(0)  // 转发计数
  threadId    String?   // Thread 分组 ID
  threadOrder Int       @default(0)  // Thread 内排序
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  tags        TagsOnPosts[]
  comments    Comment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, createdAt(sort: Desc)])
  @@index([published, publishedAt(sort: Desc)])
  @@index([authorId])
  @@index([slug])
}

model Tag {
  id    String        @id @default(cuid())
  name  String        @unique
  slug  String        @unique
  posts TagsOnPosts[]
}

model TagsOnPosts {
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String
  @@id([postId, tagId])
}

model Comment {
  id          String   @id @default(cuid())
  content     String
  approved    Boolean  @default(false)
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
  guestName    String?  // 访客昵称（未登录时使用）
  guestEmail   String?  // 访客邮箱（选填）
  guestWebsite String?  // 访客网站（选填）
  ip           String?  @default("")
  riskScore    Int      @default(0)  // AI 评论风险评分 0-100
  riskReasons  String   @default("[]")  // JSON 数组，风险原因列表
  postId      String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  createdAt DateTime @default(now())

  @@index([postId, approved])
  @@index([postId, approved, createdAt(sort: Desc)])
  @@index([authorId])
  @@index([parentId])
  @@index([riskScore])
}

model SiteConfig {
  id          String @id @default("singleton")
  siteName    String @default("我的博客")
  siteDesc    String @default("")
  loginPath   String @default("/admin-login")
  loginMode   String @default("path")  // path | secret-click | both
  secretClicks Int   @default(5)
  commentApproval Boolean @default(true)
  showCommentIp Boolean @default(false)
  enableAiDetection Boolean @default(true)  // 启用 AI 垃圾评论检测
  aiReviewStrength String @default("balanced")  // 评审强度：lenient|balanced|strict
  aiAutoApprove Boolean @default(true)  // AI 判断安全时自动通过
  
  // AI 模型配置（新增：支持自定义模型接口）
  enableCustomAiModel Boolean @default(false)  // 是否使用自定义 AI 模型
  aiModelName     String @default("")  // 当前使用的模型名称
  aiModelProvider String @default("openrouter")  // 模型提供商：openrouter|custom|others
  aiModelBaseUrl  String @default("")  // 自定义模型基础 URL（如使用自定义接口）
  aiModelApiKey   String @default("")  // AI 模型 API 密钥
  aiModelMaxTokens Int @default(2000)  // 最大上下文 token 数
  aiModelTimeout  Int @default(30)  // 超时时间（秒）
  
  // 保留原有字段（向后兼容）
  openrouterApiKey String @default("")  // OpenRouter API 密钥（已弃用，使用 aiModelApiKey）
  openrouterModel String @default("claude-3.5-sonnet")  // 使用的 AI 模型（已弃用，使用 aiModelName）
  
  emailSubjectNewComment String @default("")  // 新评论通知邮件标题
  emailSubjectReply String @default("")  // 回复通知邮件标题
  emailSubjectApproved String @default("")  // 审核通过通知邮件标题
  emailSenderName String @default("")  // 邮件发件人名称
  socialX      String @default("")
  socialGithub String @default("")
  socialEmail  String @default("")
  navItems     String @default("[{\"label\":\"首页\",\"href\":\"/\",\"icon\":\"home\"},{\"label\":\"归档\",\"href\":\"/archive\",\"icon\":\"archive\"},{\"label\":\"标签\",\"href\":\"/tags\",\"icon\":\"tag\"},{\"label\":\"友链\",\"href\":\"/links\",\"icon\":\"link\"},{\"label\":\"关于\",\"href\":\"/about\",\"icon\":\"user\"}]")
  siteLogo     String @default("{\"type\":\"text\",\"value\":\"✕\"}")
  siteIcon     String @default("")
  rightPanelWidgets String @default("[{\"type\":\"search\",\"enabled\":true},{\"type\":\"about\",\"enabled\":true},{\"type\":\"tags\",\"enabled\":true},{\"type\":\"hotPosts\",\"enabled\":true}]")
  copyright    String @default("")
  defaultTheme String @default("dark")
  customDomain String @default("")
  visitorGeoMode String @default("ip9")
  visitorGeoKey String @default("")
  visitorGeoEndpoint String @default("")
  visitorMapSource String @default("carto_positron")
  visitorStatsDisplay String @default("[\"总访问\",\"今日访问\",\"7 日访问\",\"14 日访问\",\"国家数\",\"精确坐标\",\"国家/省份落点\",\"最近时间\"]")
  storageDriver String @default("local")
  storageS3Endpoint String @default("")
  storageS3Region String @default("auto")
  storageS3Bucket String @default("")
  storageS3AccessKeyId String @default("")
  storageS3SecretAccessKey String @default("")
  storageS3Prefix String @default("uploads/")
  storageS3ForcePathStyle Boolean @default(false)
  storagePublicBaseUrl String @default("")
  storageSmmsToken String @default("")
  sidebarFriendLinksCollapsed Boolean @default(false)
  enableFriendCircle Boolean @default(false)
  groqApiKey String @default("")
  commentAiProvider String @default("")
  commentAiModel String @default("")
  friendLinkAiProvider String @default("")
  friendLinkAiModel String @default("")
  voicePolishAiProvider String @default("")
  voicePolishAiModel String @default("")
  postPolishAiProvider String @default("")
  postPolishAiModel String @default("")
  keywordRadarEnabled Boolean @default(false)
  keywordRadarKeywords String @default("")
  keywordRadarTags String @default("")
  keywordRadarExtraFeeds String @default("")
  keywordRadarIncludeDomains String @default("")
  keywordRadarExcludeDomains String @default("")
  keywordRadarScheduleMinutes Int @default(180)
  keywordRadarAutoPublish Boolean @default(true)
  keywordRadarUseAi Boolean @default(true)
  keywordRadarStandardMarkdown Boolean @default(true)
  keywordRadarPrompt String @default("")
  keywordRadarLastRunAt String @default("")
  keywordRadarLastStatus String @default("")
  keywordRadarLastMessage String @default("")
  keywordRadarLastPostId String @default("")
  keywordRadarMaxItems Int @default(12)
  keywordRadarKeepDays Int @default(14)
  keywordRadarMaxArticleAgeDays Int @default(7)
  keywordRadarSources String @default("[\"google\"]")
  keywordRadarCustomSourceTemplates String @default("[]")
  keywordRadarWebhookUrl String @default("")
  keywordRadarWebhookEnabled Boolean @default(false)
  keywordRadarUseShortLinks Boolean @default(false)
}

model Visitor {
  id         String   @id @default(cuid())
  ip         String
  path       String
  userAgent  String?  @default("")
  referrer   String?  @default("")
  country    String?  @default("")
  countryCode String? @default("")
  region     String?  @default("")
  city       String?  @default("")
  lat        Float?
  lon        Float?
  visitDay   String   @default("")
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([visitDay, createdAt])
  @@index([ip, createdAt])
  @@index([countryCode, createdAt])
}

model VisitorGeoCache {
  ip          String   @id
  country     String   @default("")
  countryCode String   @default("")
  region      String   @default("")
  city        String   @default("")
  lat         Float?
  lon         Float?
  updatedAt   DateTime @default(now())
}

model AdminAuditLog {
  id            String   @id
  action        String
  summary       String   @default("")
  targetType    String?
  targetId      String?
  riskLevel     String   @default("high")
  status        String   @default("success")
  actorId       String   @default("")
  actorUsername String   @default("")
  ip            String   @default("")
  metadata      String   @default("")
  createdAt     DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([riskLevel, status, createdAt(sort: Desc)])
}

model FriendLink {
  id          String    @id @default(cuid())
  name        String    // 网站名称
  url         String    // 网站URL
  description String?   // 网站描述
  favicon     String?   // 网站图标URL
  email       String?   // 提交者邮箱
  
  // 审核相关
  status      String    @default("pending")  // pending | approved | rejected
  rejectionReason String? // 拒绝原因
  aiScore     Int       @default(0)  // AI 风险评分 0-100（分数越低越安全）
  aiReview    String    @default("{}")  // AI 审核结论 JSON
  sortOrder   Int       @default(0)  // 手动排序权重（越大越靠前）
  showInSidebar Boolean @default(true) // 是否在右侧栏友链区显示
  
  // 互链检查
  reciprocalChecked Boolean @default(false)  // 是否检查过互链
  hasReciprocal     Boolean @default(false)  // 是否已返向链接
  reciprocalCheckTime DateTime?              // 最后检查时间
  
  createdAt   DateTime  @default(now())
  approvedAt  DateTime?
  updatedAt   DateTime  @updatedAt
  
  @@index([status, createdAt(sort: Desc)])
  @@index([hasReciprocal, status])
  @@index([status, showInSidebar, sortOrder])
}

model GuestbookMessage {
  id           String   @id @default(cuid())
  content      String
  guestName    String
  guestEmail   String?
  guestWebsite String?
  ip           String   @default("")
  approved     Boolean  @default(false)
  riskScore    Int      @default(0)
  riskReasons  String   @default("[]")
  authorId     String?
  author       User?    @relation(fields: [authorId], references: [id])
  createdAt    DateTime @default(now())

  @@index([approved, createdAt(sort: Desc)])
  @@index([authorId])
  @@index([riskScore])
}

model ShortLink {
  code       String   @id       // 6-char base62 code
  url        String             // original URL
  clicks     Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([url])
}

