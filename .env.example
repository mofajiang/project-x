DATABASE_URL="file:./data/blog.db"
JWT_SECRET="your-super-secret-jwt-key"
SESSION_SECRET="your-session-secret-32chars-min"
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# License verification (optional — omit both to disable license checks entirely)
# LICENSE_SERVER_URL="https://your-license-server.example.com"
# LICENSE_SECRET="your-license-hmac-secret"

# 邮件通知（可选，不填则禁用邮件功能）
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_USER="your@email.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="your@email.com"  # 可选，默认使用 SMTP_USER

# 存储驱动（local | s3）
STORAGE_DRIVER="local"

# S3 兼容存储配置（仅 STORAGE_DRIVER=s3 时生效）
STORAGE_S3_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
STORAGE_S3_REGION="auto"
STORAGE_S3_BUCKET="your-bucket"
STORAGE_S3_ACCESS_KEY_ID="your-access-key"
STORAGE_S3_SECRET_ACCESS_KEY="your-secret-key"
STORAGE_S3_PREFIX="uploads/"
STORAGE_S3_FORCE_PATH_STYLE="false"

# 公网访问前缀（用于返回文件 URL）
# 例如: https://cdn.example.com
STORAGE_PUBLIC_BASE_URL=""

# 图床（SM.MS，可选，支持 STORAGE_DRIVER=smms）
STORAGE_SMMS_TOKEN=""

# 服务端口
PORT="3000"

# License 验证（可选，不填则使用默认值）
LICENSE_SECRET=""
LICENSE_SERVER_URL=""

# MaxMind GeoLite2 离线库更新（可选，不填则使用免费 geoip-lite）
MAXMIND_LICENSE_KEY=""
