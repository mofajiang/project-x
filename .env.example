DATABASE_URL="file:./data/blog.db"
JWT_SECRET="your-super-secret-jwt-key"
SESSION_SECRET="your-session-secret-32chars-min"
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# 授权服务器（license-server）
# 授权服务器的访问地址，留空则使用内置默认地址
LICENSE_SERVER_URL="http://your-license-server-ip:3001"
# HMAC 签名密钥，须与授权服务器 .env 中 LICENSE_SECRET 完全一致
LICENSE_SECRET="Project-X-Blog"
# 管理员密钥，用于设置页查询/管理授权域名（与授权服务器 ADMIN_KEY 一致）
LICENSE_ADMIN_KEY="your-random-admin-key"

# 邮件通知（可选，不填则禁用邮件功能）
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_USER="your@email.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="your@email.com"  # 可选，默认使用 SMTP_USER
